     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Транзакций: 10565, пример: ['Model_ 5 Series', 'Year_2013-2015', 'Price_low', 'Trans_Automatic', 'Mileage_medium', 'Fuel_Diesel', 'Tax_low', 'MPG_50-70', 'Engine_1.5-2.0']\n"
     ]
    }
   ],
   "source": [
    "# Дискретизация и формирование транзакций\n",
    "df_proc = df.copy()\n",
    "\n",
    "# Год\n",
    "bins_y = [2012, 2015, 2017, 2019, 2021]\n",
    "labels_y = ['Year_2013-2015','Year_2016-2017','Year_2018-2019','Year_2020']\n",
    "df_proc['year_cat'] = pd.cut(df['year'], bins=bins_y, labels=labels_y, include_lowest=True)\n",
    "\n",
    "# Цена (квартили)\n",
    "df_proc['price_cat'] = pd.qcut(df['price'], 4, labels=['Price_low','Price_medium','Price_high','Price_veryhigh'])\n",
    "\n",
    "# Пробег\n",
    "bins_m = [0, 20000, 50000, 100000, 200000]\n",
    "labels_m = ['Mileage_verylow','Mileage_low','Mileage_medium','Mileage_high']\n",
    "df_proc['mileage_cat'] = pd.cut(df['mileage'], bins=bins_m, labels=labels_m, include_lowest=True)\n",
    "\n",
    "# Налог\n",
    "bins_t = [-1, 30, 150, 300, 600]\n",
    "labels_t = ['Tax_zero','Tax_low','Tax_medium','Tax_high']\n",
    "df_proc['tax_cat'] = pd.cut(df['tax'], bins=bins_t, labels=labels_t, include_lowest=True)\n",
    "\n",
    "# MPG\n",
    "bins_mpg = [0, 30, 50, 70, 500]\n",
    "labels_mpg = ['MPG_<30','MPG_30-50','MPG_50-70','MPG_>70']\n",
    "df_proc['mpg_cat'] = pd.cut(df['mpg'], bins=bins_mpg, labels=labels_mpg, include_lowest=True)\n",
    "\n",
    "# Объём двигателя\n",
    "bins_e = [0, 1.5, 2.0, 3.0, 5.0]\n",
    "labels_e = ['Engine_<1.5','Engine_1.5-2.0','Engine_2.0-3.0','Engine_>3.0']\n",
    "df_proc['engineSize_cat'] = pd.cut(df['engineSize'], bins=bins_e, labels=labels_e, include_lowest=True)\n",
    "\n",
    "# Категориальные\n",
    "df_proc['model_item'] = 'Model_' + df['model'].astype(str)\n",
    "df_proc['transmission_item'] = 'Trans_' + df['transmission'].astype(str)\n",
    "df_proc['fuelType_item'] = 'Fuel_' + df['fuelType'].astype(str)\n",
    "\n",
    "item_cols = ['model_item','year_cat','price_cat','transmission_item',\n",
    "             'mileage_cat','fuelType_item','tax_cat','mpg_cat','engineSize_cat']\n",
    "\n",
    "df_proc.dropna(subset=item_cols, inplace=True)\n",
    "\n",
    "transactions = df_proc[item_cols].values.tolist()\n",
    "transactions = [list(map(str, t)) for t in transactions]  # гарантируем строки\n",
    "N = len(transactions)\n",
    "print(f\"Транзакций: {N}, пример: {transactions[0]}\")"
   ]
  },
