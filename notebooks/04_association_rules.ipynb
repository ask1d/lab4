   "source": [
    "# Эксперименты с разными min_support и min_confidence\n",
    "min_sups = [0.01, 0.02, 0.03, 0.05, 0.1, 0.15, 0.2]\n",
    "min_confs = [0.5, 0.7, 0.9]\n",
    "results = []\n",
    "\n",
    "for minsup in min_sups:\n",
    "    print(f\"min_support = {minsup}\")\n",
    "    t0 = time.time()\n",
    "    freq = fpgrowth(transactions, minsup)\n",
    "    t_fp = time.time() - t0\n",
    "    \n",
    "    for minconf in min_confs:\n",
    "        rules_df = generate_rules_fp(freq, minconf, N, min_lift=1.0)\n",
    "        results.append(dict(min_support=minsup, min_confidence=minconf,\n",
    "                            num_freq=len(freq), num_rules=len(rules_df),\n",
    "                            time_fp=t_fp))\n",
    "        print(f\"  conf={minconf}: частых наборов {len(freq)}, правил {len(rules_df)}\")\n",
    "\n",
    "summary = pd.DataFrame(results)\n",
    "display(summary)"
   ]
  },
